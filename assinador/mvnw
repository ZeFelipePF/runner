# Maven Wrapper script for Unix

set -euf

MAVEN_PROJECTBASEDIR="${MAVEN_PROJECTBASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
export MAVEN_PROJECTBASEDIR

WRAPPER_JAR="${MAVEN_PROJECTBASEDIR}/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"

if [ -n "${JAVA_HOME:-}" ]; then
  if [ -x "${JAVA_HOME}/bin/java" ]; then
    JAVACMD="${JAVA_HOME}/bin/java"
  else
    echo "ERROR: JAVA_HOME is set to an invalid directory: ${JAVA_HOME}" >&2
    exit 1
  fi
else
  JAVACMD="$(command -v java)" || true
  if [ -z "${JAVACMD}" ]; then
    echo "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH." >&2
    exit 1
  fi
fi

if [ ! -f "${WRAPPER_JAR}" ]; then
  echo "Downloading Maven Wrapper..."
  if command -v curl > /dev/null 2>&1; then
    curl -sL -o "${WRAPPER_JAR}" "${WRAPPER_URL}"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "${WRAPPER_JAR}" "${WRAPPER_URL}"
  else
    echo "ERROR: Cannot download maven-wrapper.jar. Install curl or wget." >&2
    exit 1
  fi
fi

exec "${JAVACMD}" \
  ${MAVEN_OPTS:-} \
  -Dmaven.multiModuleProjectDirectory="${MAVEN_PROJECTBASEDIR}" \
  -classpath "${WRAPPER_JAR}" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"
